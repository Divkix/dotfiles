[user]
	name = Divanshu Chauhan
	email = divkix@divkix.me
	signingkey = /Users/divkix/.ssh/DivMBP-Personal.pub
[core]
    eol = lf
    autocrlf = input
    editor = zed --wait          # was: code --wait --new-window
    excludesfile = /Users/divkix/.gitignore_global
[format]
	signoff = true
[commit]
	gpgsign = true
	template = /Users/divkix/.stCommitMsg
[credential "https://github.com"]
	helper = 
	helper = !/opt/homebrew/bin/gh auth git-credential
[trailer "sign"]
	key = "Signed-off-by: "
	ifmissing = add
	ifexists = doNothing
	command = echo \"$(git config user.name) <$(git config user.email)>\"
[init]
	defaultBranch = main
[pull]
	ff = only
[tag]
	forceSignAnnotated = true
	gpgSign = true
[credential]
	helper = cache --timeout=3600
[filter "lfs"]
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f
	process = git-lfs filter-process
	required = true
[push]
	autoSetupRemote = true
	followTags = true
[diff]
    tool = zed                   # was: vscode
[difftool "zed"]                 # was: [difftool "vscode"]
    cmd = zed --wait --diff $LOCAL $REMOTE
[difftool]
    prompt = false
[merge]
    tool = vscode                # KEEP this for now — Zed can't do mergetool yet
[mergetool "vscode"]             # KEEP this too
    cmd = code --wait $MERGED
[lfs "customtransfer.xet"]
	path = git-xet
	args = transfer
	concurrent = true
[credential "https://gist.github.com"]
	helper = 
	helper = !/opt/homebrew/bin/gh auth git-credential
[coderabbit]
	machineId = cli/8b836f09efb547c48aceecc236128f8f
[alias]
	prune-local = !git fetch --prune && git branch -vv | grep ': gone]' | awk '{print $1}' | xargs -r git branch -d
	prune-local-d = !git fetch --prune && git branch -vv | grep ': gone]' | awk '{print $1}' | xargs -r git branch -D
[fetch]
	prune = true
[gpg]
	format = ssh
[gpg "ssh"]
	allowedSignersFile = /Users/divkix/.ssh/allowed_signers
